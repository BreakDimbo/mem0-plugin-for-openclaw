{
  "id": "memory-mem0",
  "name": "memory-mem0",
  "description": "Enhanced memory plugin with local core memory, mem0 long-term recall, scoped retrieval, and async capture",
  "kind": "memory",
  "version": "1.0.0",
  "uiHints": {
    "userId": {
      "label": "User ID",
      "placeholder": "default_user",
      "help": "Default user identifier for memory storage"
    },
    "scope.userIdByAgent": {
      "label": "Per-Agent User IDs",
      "advanced": true,
      "help": "Optional agentId -> userId mapping for multi-agent isolation"
    },
    "autoCapture": {
      "label": "Auto-Capture",
      "help": "Automatically capture durable facts from user messages"
    },
    "autoRecall": {
      "label": "Auto-Recall",
      "help": "Automatically inject relevant memories into agent context"
    },
    "scoreThreshold": {
      "label": "Relevance Threshold",
      "placeholder": "0.30",
      "advanced": true,
      "help": "Minimum relevance score for memory injection (0.0-1.0)"
    },
    "recall.hybrid.enabled": {
      "label": "Hybrid Recall",
      "advanced": true,
      "help": "Use /retrieve/hybrid for recall when available"
    },
    "recall.hybrid.alpha": {
      "label": "Hybrid Alpha",
      "placeholder": "0.7",
      "advanced": true,
      "help": "Vector weight in hybrid retrieval (0.0-1.0)"
    },
    "backend.freeText.provider": {
      "label": "Free-Text Backend",
      "advanced": true,
      "help": "Current free-text backend (mem0 only)"
    },
    "mem0.mode": {
      "label": "Mem0 Mode",
      "advanced": true,
      "help": "Use Mem0 platform or open-source OSS backend"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "backend": {
        "type": "object",
        "properties": {
          "freeText": {
            "type": "object",
            "properties": {
              "provider": { "type": "string", "enum": ["mem0"], "default": "mem0" }
            }
          }
        }
      },
      "mem0": {
        "type": "object",
        "properties": {
          "mode": { "type": "string", "enum": ["platform", "open-source"], "default": "open-source" },
          "apiKey": { "type": "string" },
          "orgId": { "type": "string" },
          "projectId": { "type": "string" },
          "enableGraph": { "type": "boolean", "default": false },
          "searchThreshold": { "type": "number", "default": 0.3, "minimum": 0, "maximum": 1 },
          "topK": { "type": "number", "default": 5, "minimum": 1, "maximum": 50 },
          "customInstructions": { "type": "string" },
          "customPrompt": { "type": "string" },
          "oss": {
            "type": "object",
            "properties": {
              "embedder": { "type": "object" },
              "vectorStore": { "type": "object" },
              "llm": { "type": "object" },
              "historyDbPath": { "type": "string" }
            }
          }
        }
      },
      "scope": {
        "type": "object",
        "properties": {
          "userId": { "type": "string", "default": "default_user" },
          "userIdByAgent": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "agentId": { "type": "string", "default": "main" },
          "tenantId": { "type": "string" },
          "requireUserId": { "type": "boolean", "default": true },
          "requireAgentId": { "type": "boolean", "default": true }
        }
      },
      "recall": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "method": { "type": "string", "enum": ["rag", "llm"], "default": "rag" },
          "hybrid": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": false },
              "alpha": { "type": "number", "default": 0.7, "minimum": 0, "maximum": 1 },
              "fallbackToRag": { "type": "boolean", "default": true }
            }
          },
          "topK": { "type": "number", "default": 3, "minimum": 1, "maximum": 20 },
          "scoreThreshold": { "type": "number", "default": 0.30, "minimum": 0, "maximum": 1 },
          "maxContextChars": { "type": "number", "default": 1200, "minimum": 200, "maximum": 5000 },
          "injectionBudgetChars": { "type": "number", "default": 1600, "minimum": 300, "maximum": 20000 },
          "cacheTtlMs": { "type": "number", "default": 60000, "minimum": 0, "maximum": 600000 },
          "cacheMaxSize": { "type": "number", "default": 100 }
        }
      },
      "core": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "topK": { "type": "number", "default": 8, "minimum": 1, "maximum": 50 },
          "maxItemChars": { "type": "number", "default": 240, "minimum": 30, "maximum": 2000 },
          "persistPath": { "type": "string", "description": "Directory for local Core Memory persistence", "default": "~/.openclaw/data/memory-memu" },
          "autoExtractProposals": { "type": "boolean", "default": true },
          "humanReviewRequired": { "type": "boolean", "default": true },
          "touchOnRecall": { "type": "boolean", "default": true },
          "proposalQueueMax": { "type": "number", "default": 200, "minimum": 10, "maximum": 5000 },
          "alwaysInjectTiers": { "type": "array", "items": { "type": "string", "enum": ["profile", "technical", "general"] }, "default": ["profile", "general"], "description": "Core memory tiers to always inject (no scoring)" },
          "retrievalOnlyTiers": { "type": "array", "items": { "type": "string", "enum": ["profile", "technical", "general"] }, "default": ["technical"], "description": "Core memory tiers that require scoring for injection" },
          "maxAlwaysInjectChars": { "type": "number", "default": 600, "minimum": 100, "maximum": 5000, "description": "Safety cap on always-inject block character count" },
          "consolidation": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": true },
              "intervalMs": { "type": "number", "default": 3600000, "minimum": 60000, "description": "Minimum interval between consolidation runs in ms (default 1 hour)" },
              "similarityThreshold": { "type": "number", "default": 0.85, "minimum": 0.5, "maximum": 1, "description": "Trigram similarity threshold for value dedup within a category" }
            }
          },
          "llmGate": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": false },
              "apiBase": { "type": "string", "default": "https://api.openai.com/v1" },
              "apiKey": { "type": "string" },
              "model": { "type": "string", "default": "gpt-4o-mini" },
              "maxTokensPerBatch": { "type": "number", "default": 2000, "minimum": 500, "maximum": 10000 },
              "timeoutMs": { "type": "number", "default": 30000, "minimum": 5000, "maximum": 120000 }
            }
          }
        }
      },
      "capture": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "maxItemsPerRun": { "type": "number", "default": 2, "minimum": 1, "maximum": 10 },
          "minChars": { "type": "number", "default": 24 },
          "maxChars": { "type": "number", "default": 500 },
          "dedupeThreshold": { "type": "number", "default": 0.8 },
          "candidateQueue": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": true },
              "intervalMs": { "type": "number", "default": 600000, "minimum": 10000, "description": "Batch processing interval in ms (default 10min)" },
              "maxBatchSize": { "type": "number", "default": 50, "minimum": 1, "maximum": 200 }
            }
          }
        }
      },
      "outbox": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "concurrency": { "type": "number", "default": 2 },
          "batchSize": { "type": "number", "default": 10 },
          "maxRetries": { "type": "number", "default": 5 },
          "drainTimeoutMs": { "type": "number", "default": 5000 },
          "persistPath": { "type": "string", "description": "Directory for outbox persistence files", "default": "~/.openclaw/data/memory-memu" },
          "flushIntervalMs": { "type": "number", "default": 10000, "description": "Outbox flush interval in milliseconds" }
        }
      },
      "sync": {
        "type": "object",
        "properties": {
          "flushToMarkdown": { "type": "boolean", "default": true },
          "flushIntervalSec": { "type": "number", "default": 300 },
          "memoryFilePath": { "type": "string", "description": "Path to MEMORY.md for sync writeback" }
        }
      },
      "classifier": {
        "type": "object",
        "description": "Unified intent classifier for query routing and capture optimization",
        "properties": {
          "enabled": { "type": "boolean", "default": true, "description": "Enable/disable unified intent classifier" },
          "model": { "type": "string", "default": "gemini-2.5-flash", "description": "LLM model for classification" },
          "apiBase": { "type": "string", "description": "API base URL (defaults to Gemini)" },
          "apiKey": { "type": "string", "description": "API key for classifier (env: MEM0_CLASSIFIER_API_KEY)" },
          "cacheTtlMs": { "type": "number", "default": 300000, "minimum": 0, "maximum": 3600000, "description": "Classification cache TTL in ms" },
          "cacheMaxSize": { "type": "number", "default": 200, "minimum": 10, "maximum": 1000, "description": "Max entries in classification cache" }
        }
      },
      "smartRouter": {
        "type": "object",
        "description": "Smart model routing based on query complexity tier",
        "properties": {
          "enabled": { "type": "boolean", "default": true, "description": "Enable/disable smart router" },
          "tierModels": {
            "type": "object",
            "description": "Model mapping per complexity tier (provider/model format)",
            "properties": {
              "SIMPLE": { "type": "string", "description": "Model for SIMPLE tier (quick facts, greetings)" },
              "MEDIUM": { "type": "string", "description": "Model for MEDIUM tier (standard tasks)" },
              "COMPLEX": { "type": "string", "description": "Model for COMPLEX tier (multi-step analysis)" },
              "REASONING": { "type": "string", "description": "Model for REASONING tier (deep thinking, architecture)" }
            }
          }
        }
      },
      "reranker": {
        "type": "object",
        "description": "Embedding-based reranker for retrieval (requires embedder config)",
        "properties": {
          "enabled": { "type": "boolean", "default": false, "description": "Enable/disable embedding reranker" },
          "threshold": { "type": "number", "default": 0.3, "minimum": 0, "maximum": 1, "description": "Score threshold for reranking" },
          "bm25Weight": { "type": "number", "default": 0.4, "minimum": 0, "maximum": 1, "description": "BM25 score weight in fusion" },
          "embeddingWeight": { "type": "number", "default": 0.6, "minimum": 0, "maximum": 1, "description": "Embedding score weight in fusion" }
        }
      }
    },
    "required": []
  }
}
