{
  "id": "memory-memu",
  "name": "memU Enhanced Memory",
  "description": "Enhanced memory plugin with memU for long-term structured recall, scoped retrieval, and async capture",
  "kind": "memory",
  "version": "1.0.0",
  "uiHints": {
    "baseUrl": {
      "label": "memU Server URL",
      "placeholder": "http://127.0.0.1:8000",
      "help": "Base URL of the memU-server instance"
    },
    "userId": {
      "label": "User ID",
      "placeholder": "default_user",
      "help": "Default user identifier for memU storage"
    },
    "scope.userIdByAgent": {
      "label": "Per-Agent User IDs",
      "advanced": true,
      "help": "Optional agentId -> userId mapping for multi-agent isolation"
    },
    "autoCapture": {
      "label": "Auto-Capture",
      "help": "Automatically capture durable facts from user messages"
    },
    "autoRecall": {
      "label": "Auto-Recall",
      "help": "Automatically inject relevant memories into agent context"
    },
    "scoreThreshold": {
      "label": "Relevance Threshold",
      "placeholder": "0.30",
      "advanced": true,
      "help": "Minimum relevance score for memory injection (0.0-1.0)"
    },
    "recall.hybrid.enabled": {
      "label": "Hybrid Recall",
      "advanced": true,
      "help": "Use /retrieve/hybrid for recall when available"
    },
    "recall.hybrid.alpha": {
      "label": "Hybrid Alpha",
      "placeholder": "0.7",
      "advanced": true,
      "help": "Vector weight in hybrid retrieval (0.0-1.0)"
    },
    "backend.freeText.provider": {
      "label": "Free-Text Backend",
      "advanced": true,
      "help": "Choose memU or mem0 as the free-text memory backend"
    },
    "mem0.mode": {
      "label": "Mem0 Mode",
      "advanced": true,
      "help": "Use Mem0 platform or open-source OSS backend"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "memu": {
        "type": "object",
        "properties": {
          "baseUrl": { "type": "string", "default": "http://127.0.0.1:8000" },
          "timeoutMs": { "type": "number", "default": 5000, "minimum": 500, "maximum": 30000 },
          "cbResetMs": { "type": "number", "default": 10000, "minimum": 1000, "maximum": 120000 },
          "healthCheckPath": { "type": "string", "default": "/debug" }
        }
      },
      "backend": {
        "type": "object",
        "properties": {
          "freeText": {
            "type": "object",
            "properties": {
              "provider": { "type": "string", "enum": ["memu", "mem0"], "default": "memu" },
              "dualWrite": { "type": "boolean", "default": false },
              "readFallback": { "type": "string", "enum": ["none", "memu"], "default": "memu" },
              "compareRecall": { "type": "boolean", "default": false }
            }
          }
        }
      },
      "mem0": {
        "type": "object",
        "properties": {
          "mode": { "type": "string", "enum": ["platform", "open-source"], "default": "open-source" },
          "apiKey": { "type": "string" },
          "orgId": { "type": "string" },
          "projectId": { "type": "string" },
          "enableGraph": { "type": "boolean", "default": false },
          "searchThreshold": { "type": "number", "default": 0.3, "minimum": 0, "maximum": 1 },
          "topK": { "type": "number", "default": 5, "minimum": 1, "maximum": 50 },
          "customInstructions": { "type": "string" },
          "customPrompt": { "type": "string" },
          "oss": {
            "type": "object",
            "properties": {
              "embedder": { "type": "object" },
              "vectorStore": { "type": "object" },
              "llm": { "type": "object" },
              "historyDbPath": { "type": "string" }
            }
          }
        }
      },
      "scope": {
        "type": "object",
        "properties": {
          "userId": { "type": "string", "default": "default_user" },
          "userIdByAgent": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "agentId": { "type": "string", "default": "main" },
          "tenantId": { "type": "string" },
          "requireUserId": { "type": "boolean", "default": true },
          "requireAgentId": { "type": "boolean", "default": true }
        }
      },
      "recall": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "method": { "type": "string", "enum": ["rag", "llm"], "default": "rag" },
          "hybrid": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": false },
              "alpha": { "type": "number", "default": 0.7, "minimum": 0, "maximum": 1 },
              "fallbackToRag": { "type": "boolean", "default": true }
            }
          },
          "topK": { "type": "number", "default": 3, "minimum": 1, "maximum": 20 },
          "scoreThreshold": { "type": "number", "default": 0.30, "minimum": 0, "maximum": 1 },
          "maxContextChars": { "type": "number", "default": 1200, "minimum": 200, "maximum": 5000 },
          "injectionBudgetChars": { "type": "number", "default": 1600, "minimum": 300, "maximum": 20000 },
          "cacheTtlMs": { "type": "number", "default": 60000, "minimum": 0, "maximum": 600000 },
          "cacheMaxSize": { "type": "number", "default": 100 }
        }
      },
      "core": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "topK": { "type": "number", "default": 8, "minimum": 1, "maximum": 50 },
          "maxItemChars": { "type": "number", "default": 240, "minimum": 30, "maximum": 2000 },
          "persistPath": { "type": "string", "description": "Directory for local Core Memory persistence", "default": "~/.openclaw/data/memory-memu" },
          "autoExtractProposals": { "type": "boolean", "default": true },
          "humanReviewRequired": { "type": "boolean", "default": true },
          "touchOnRecall": { "type": "boolean", "default": true },
          "proposalQueueMax": { "type": "number", "default": 200, "minimum": 10, "maximum": 5000 }
        }
      },
      "capture": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "maxItemsPerRun": { "type": "number", "default": 2, "minimum": 1, "maximum": 10 },
          "minChars": { "type": "number", "default": 24 },
          "maxChars": { "type": "number", "default": 500 },
          "dedupeThreshold": { "type": "number", "default": 0.8 }
        }
      },
      "outbox": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "concurrency": { "type": "number", "default": 2 },
          "batchSize": { "type": "number", "default": 10 },
          "maxRetries": { "type": "number", "default": 5 },
          "drainTimeoutMs": { "type": "number", "default": 5000 },
          "persistPath": { "type": "string", "description": "Directory for outbox persistence files", "default": "~/.openclaw/data/memory-memu" },
          "flushIntervalMs": { "type": "number", "default": 10000, "description": "Outbox flush interval in milliseconds" }
        }
      },
      "sync": {
        "type": "object",
        "properties": {
          "flushToMarkdown": { "type": "boolean", "default": true },
          "flushIntervalSec": { "type": "number", "default": 300 },
          "memoryFilePath": { "type": "string", "description": "Path to MEMORY.md for sync writeback" }
        }
      }
    },
    "required": []
  }
}
