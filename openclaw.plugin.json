{
  "id": "memory-mem0",
  "name": "memory-mem0",
  "description": "Enhanced memory plugin with local core memory, mem0 long-term recall, scoped retrieval, and async capture",
  "kind": "memory",
  "version": "1.1.0",
  "uiHints": {
    "userId": {
      "label": "User ID",
      "placeholder": "default_user",
      "help": "Default user identifier for memory storage"
    },
    "scope.userIdByAgent": {
      "label": "Per-Agent User IDs",
      "advanced": true,
      "help": "Optional agentId -> userId mapping for multi-agent isolation"
    },
    "backend.freeText.provider": {
      "label": "Free-Text Backend",
      "advanced": true,
      "help": "Current free-text backend (mem0 only)"
    },
    "mem0.mode": {
      "label": "Mem0 Mode",
      "advanced": true,
      "help": "Use Mem0 platform or open-source OSS backend"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "dataDir": {
        "type": "string",
        "description": "Base data directory for all persistence (core memory, outbox, etc.)",
        "default": "~/.openclaw/data/memory-mem0"
      },
      "geminiApiKey": {
        "type": "string",
        "description": "Legacy alias for the shared LLM API key"
      },
      "kimiApiKey": {
        "type": "string",
        "description": "Shared Kimi Coding API key for classifier, llmGate, and mem0 LLM"
      },
      "backend": {
        "type": "object",
        "properties": {
          "freeText": {
            "type": "object",
            "properties": {
              "provider": { "type": "string", "enum": ["mem0"], "default": "mem0" }
            }
          }
        }
      },
      "mem0": {
        "type": "object",
        "properties": {
          "mode": { "type": "string", "enum": ["platform", "open-source"], "default": "open-source" },
          "apiKey": { "type": "string" },
          "orgId": { "type": "string" },
          "projectId": { "type": "string" },
          "enableGraph": { "type": "boolean", "default": false },
          "searchThreshold": { "type": "number", "default": 0.3, "minimum": 0, "maximum": 1 },
          "topK": { "type": "number", "default": 5, "minimum": 1, "maximum": 50 },
          "customInstructions": { "type": "string" },
          "customPrompt": { "type": "string" },
          "oss": {
            "type": "object",
            "properties": {
              "embedder": { "type": "object" },
              "vectorStore": { "type": "object" },
              "llm": { "type": "object" },
              "historyDbPath": { "type": "string" },
              "graph_store": {
                "type": "object",
                "description": "Neo4j graph store config. A separate graph_store.llm override is usually unnecessary; when enableGraph=true and llm provider is google/gemini, the plugin rewrites it to Google's OpenAI-compatible endpoint automatically."
              }
            }
          }
        }
      },
      "scope": {
        "type": "object",
        "properties": {
          "userId": { "type": "string", "default": "default_user" },
          "userIdByAgent": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "agentId": { "type": "string", "default": "main" },
          "tenantId": { "type": "string" }
        }
      },
      "recall": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "topK": { "type": "number", "default": 5, "minimum": 1, "maximum": 20 },
          "threshold": { "type": "number", "default": 0.25, "minimum": 0, "maximum": 1, "description": "Minimum relevance score (renamed from scoreThreshold)" },
          "maxChars": { "type": "number", "default": 1500, "minimum": 200, "maximum": 5000, "description": "Max injection chars (renamed from maxContextChars)" },
          "cacheTtlMs": { "type": "number", "default": 60000, "minimum": 0, "maximum": 600000 },
          "cacheMaxSize": { "type": "number", "default": 100 }
        }
      },
      "core": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "topK": { "type": "number", "default": 10, "minimum": 1, "maximum": 50 },
          "maxItemChars": { "type": "number", "default": 300, "minimum": 30, "maximum": 2000 },
          "persistPath": { "type": "string", "description": "Directory for local Core Memory persistence (deprecated, use dataDir)" },
          "autoExtractProposals": { "type": "boolean", "default": true },
          "humanReviewRequired": { "type": "boolean", "default": false },
          "touchOnRecall": { "type": "boolean", "default": true },
          "proposalQueueMax": { "type": "number", "default": 200, "minimum": 10, "maximum": 5000 },
          "alwaysInjectTiers": { "type": "array", "items": { "type": "string", "enum": ["profile", "technical", "general"] }, "default": ["profile", "general"], "description": "Core memory tiers to always inject (no scoring)" },
          "alwaysInjectLimit": { "type": "number", "default": 800, "minimum": 100, "maximum": 5000, "description": "Max chars for always-inject (renamed from maxAlwaysInjectChars)" },
          "consolidation": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": true },
              "intervalMs": { "type": "number", "default": 3600000, "minimum": 60000, "description": "Minimum interval between consolidation runs in ms (default 1 hour)" },
              "similarityThreshold": { "type": "number", "default": 0.85, "minimum": 0.5, "maximum": 1, "description": "Trigram similarity threshold for value dedup within a category" }
            }
          },
          "llmGate": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": false },
              "apiBase": { "type": "string", "default": "https://api.kimi.com/coding/" },
              "apiKey": { "type": "string", "description": "API key (inherits from kimiApiKey or legacy geminiApiKey if not set)" },
              "model": { "type": "string", "default": "k2p5" },
              "maxTokensPerBatch": { "type": "number", "default": 4000, "minimum": 500, "maximum": 10000 },
              "timeoutMs": { "type": "number", "default": 60000, "minimum": 5000, "maximum": 120000 }
            }
          }
        }
      },
      "capture": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "minChars": { "type": "number", "default": 20 },
          "maxChars": { "type": "number", "default": 600 },
          "maxConversationTurns": { "type": "number", "default": 6, "minimum": 1, "maximum": 20, "description": "How many recent user turns to capture as a conversation window" },
          "dedupeThreshold": { "type": "number", "default": 0.8 },
          "candidateQueue": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": true },
              "intervalMs": { "type": "number", "default": 10000, "minimum": 1000, "description": "Batch processing interval in ms" },
              "maxBatchSize": { "type": "number", "default": 50, "minimum": 1, "maximum": 200 }
            }
          }
        }
      },
      "outbox": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "concurrency": { "type": "number", "default": 2 },
          "batchSize": { "type": "number", "default": 10 },
          "maxRetries": { "type": "number", "default": 5 },
          "drainTimeoutMs": { "type": "number", "default": 5000 },
          "persistPath": { "type": "string", "description": "Directory for outbox persistence (deprecated, use dataDir)" },
          "flushIntervalMs": { "type": "number", "default": 10000, "description": "Outbox flush interval in milliseconds" }
        }
      },
      "sync": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true, "description": "Enable Markdown sync (renamed from flushToMarkdown)" },
          "intervalMs": { "type": "number", "default": 300000, "description": "Sync interval in ms (renamed from flushIntervalSec)" },
          "memoryFilePath": { "type": "string", "description": "Path to MEMORY.md for sync writeback" }
        }
      },
      "classifier": {
        "type": "object",
        "description": "Unified intent classifier for query routing and capture optimization",
        "properties": {
          "enabled": { "type": "boolean", "default": true, "description": "Enable/disable unified intent classifier" },
          "model": { "type": "string", "default": "k2p5", "description": "LLM model for classification" },
          "apiBase": { "type": "string", "default": "https://api.kimi.com/coding/", "description": "API base URL" },
          "apiKey": { "type": "string", "description": "API key (inherits from kimiApiKey or legacy geminiApiKey if not set)" },
          "cacheTtlMs": { "type": "number", "default": 300000, "minimum": 0, "maximum": 3600000, "description": "Classification cache TTL in ms" },
          "cacheMaxSize": { "type": "number", "default": 200, "minimum": 10, "maximum": 1000, "description": "Max entries in classification cache" }
        }
      },
      "smartRouter": {
        "type": "object",
        "description": "Smart model routing based on query complexity tier",
        "properties": {
          "enabled": { "type": "boolean", "default": false, "description": "Enable/disable smart router" },
          "tierModels": {
            "type": "object",
            "description": "Model mapping per complexity tier (provider/model format)",
            "properties": {
              "SIMPLE": { "type": "string", "description": "Model for SIMPLE tier (quick facts, greetings)" },
              "MEDIUM": { "type": "string", "description": "Model for MEDIUM tier (standard tasks)" },
              "COMPLEX": { "type": "string", "description": "Model for COMPLEX tier (multi-step analysis)" },
              "REASONING": { "type": "string", "description": "Model for REASONING tier (deep thinking, architecture)" }
            }
          }
        }
      }
    },
    "required": []
  }
}
